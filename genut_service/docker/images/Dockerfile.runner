# GENUT 실행용 툴체인 이미지.
# job 워크스페이스는 /work 에 bind-mount 되며, GENUT CLI가 이 안에서 실행된다.
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    cmake \
    ninja-build \
    clang \
 && rm -rf /var/lib/apt/lists/*

# 참고: kunit 빌드가 필요한 경우 커널 헤더/툴체인을 추가로 설치한다.
# GENUT가 필요로 하는 파이썬 의존성도 여기서 설치한다.

WORKDIR /work
CMD ["bash"]
