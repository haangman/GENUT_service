# === GENUT_service 설정 ===
# 이 파일을 .env로 복사한 뒤 값을 채운다.

# 데이터베이스 (SQLite 기본, 추후 Postgres 예: postgresql+psycopg://user:pass@host/db)
DB_URL=sqlite:///./genut_service.db

# job별 작업 디렉터리 루트
WORKSPACE_ROOT=./_workspaces

# GENUT CLI 실행 타임아웃(초)
GENUT_RUN_TIMEOUT=1800

# git clone/fetch 타임아웃(초)
GIT_TIMEOUT=300

# 웹 터미널 페이지 (Linux/WSL·Docker 전용). 웹으로 셸을 노출하므로 신뢰 네트워크에서만.
TERMINAL_ENABLED=true
# 터미널 셸(빈 값=$SHELL→/bin/bash→/bin/sh 자동)
TERMINAL_SHELL=

# 인프라성 실패 재시도 횟수
JOB_MAX_INFRA_RETRIES=1

# 스케줄러 tick 간격(초)
SCHEDULER_INTERVAL=1.0

# Docker 실행 설정 (M8)
DOCKER_IMAGE=genut-runner:latest
DOCKER_CPUS=2.0
DOCKER_MEMORY=2g
